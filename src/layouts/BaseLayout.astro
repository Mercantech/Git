---
interface Props {
  title: string;
  description?: string;
  currentPath?: string;
}

const { title, description = 'Introduktion til Git og GitHub', currentPath = '/' } = Astro.props;

const navItems = [
  { href: '/', label: 'home', path: '/' },
  { href: '/commits', label: 'commits', path: '/commits' },
  { href: '/branches', label: 'branches', path: '/branches' },
  { href: '/pull-requests', label: 'prs', path: '/pull-requests' },
  { href: '/merge', label: 'merge', path: '/merge' },
  { href: '/issues', label: 'issues', path: '/issues' },
  { href: '/releases', label: 'releases', path: '/releases' },
];
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | git --learn</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-logo" aria-label="Forside">{'~/git [main]'}</a>
        <nav class="site-nav" aria-label="Hovednavigation">
          {navItems.map((item) => (
            <a href={item.href} aria-current={currentPath === item.path ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span class="site-footer__status">[OK]</span> git-learn v0.1.0 — mercantec.tech
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
