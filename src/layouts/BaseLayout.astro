---
interface Props {
  title: string;
  description?: string;
  currentPath?: string;
  wide?: boolean;
}

const { title, description = 'Introduktion til Git og GitHub', currentPath = '/', wide = false } = Astro.props;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Git & GitHub</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-logo">Git & GitHub</a>
        <nav class="site-nav" aria-label="Hovednavigation">
          <a href="/" aria-current={currentPath === '/' ? 'page' : undefined}>Forside</a>
          <a href="/commits" aria-current={currentPath === '/commits' ? 'page' : undefined}>Commits</a>
          <a href="/branches" aria-current={currentPath === '/branches' ? 'page' : undefined}>Branches</a>
          <a href="/pull-requests" aria-current={currentPath === '/pull-requests' ? 'page' : undefined}>PRs</a>
          <a href="/merge" aria-current={currentPath === '/merge' ? 'page' : undefined}>Merge</a>
          <a href="/issues" aria-current={currentPath === '/issues' ? 'page' : undefined}>Issues</a>
          <a href="/releases" aria-current={currentPath === '/releases' ? 'page' : undefined}>Releases</a>
        </nav>
        <button
          type="button"
          class="present-toggle"
          data-present-toggle
          aria-pressed="false"
          aria-label="Start præsentationstilstand"
        >
          Præsentation
        </button>
      </div>
    </header>

    <main class:list={[{ 'site-main--wide': wide }]}>
      <slot />
    </main>

    <footer class="site-footer">
      Interaktiv introduktion til Git og GitHub
    </footer>

    <div class="present-controls" data-present-controls hidden>
      <button type="button" class="present-controls__btn present-controls__btn--icon" data-present-prev aria-label="Forrige slide">←</button>
      <span class="present-controls__counter" data-present-counter>1 / 1</span>
      <button type="button" class="present-controls__btn present-controls__btn--icon" data-present-next aria-label="Næste slide">→</button>
      <button type="button" class="present-controls__btn" data-present-fullscreen aria-label="Fuld skærm">Fuld skærm</button>
      <button type="button" class="present-controls__btn" data-present-exit aria-label="Afslut præsentation">Afslut</button>
      <span class="present-controls__hint" aria-hidden="true">← → mellemrum · Esc afslut · F fuld skærm</span>
    </div>

    <script>
      import '../scripts/present-mode';
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
  @import '../styles/present.css';
</style>
